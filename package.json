{
  "name": "coactl",
  "version": "0.1.0",
  "description": "CLI + registry for defining agent assets once and syncing them to multiple AI coding tools.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "coactl": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
