    "cli": "tsx src/cli/index.ts",
    "dashboard": "tsx src/cli/index.ts dashboard"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^5.2.1",
    "ora": "^9.4.0",
    "react": "^18.3.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.1"
  }
